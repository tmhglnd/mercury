                            {
                                "box": {
                                    "code": "// Ducking Effect\r\n// A simple ducking effect that applies an inverted \r\n// logarithmic amplitude ramp on the incoming signal\r\n// based on receiving a click in the right inlet.\r\n\r\nParam attack(88);\r\nParam release(3528);\r\nParam depth(1);\r\nHistory started(0);\r\nHistory count(0);\r\n\r\n// If click received start the ramp up\r\nif (in3 > 0){\r\n    started = 1;\r\n    count = 0;\r\n}\r\n// Stop count if greater than attack time + 1 sample\r\nif (count > attack){\r\n    started = 0; \r\n    count = 0;\r\n}\r\n// The duck is a logarithmic slide applied to the 0/1 signal\r\nduck = slide(count > 0, attack*0.35, release*0.35);\r\nreduce = 1 - duck * depth;\r\n\r\nout1 = in1 * reduce;\r\nout2 = in2 * reduce;\r\n\r\n// Count for attack time\r\nif (started){\r\n    count += 1;\r\n}\r\n",
                                    "fontface": 0,
                                    "fontname": "<Monospaced>",
                                    "fontsize": 12.0,
                                    "id": "obj-12",
                                    "maxclass": "codebox",
                                    "numinlets": 3,
                                    "numoutlets": 2,
                                    "outlettype": [ "", "" ],
                                    "patching_rect": [ 45.0, 75.0, 540.0, 525.0 ]
                                }
                            },
